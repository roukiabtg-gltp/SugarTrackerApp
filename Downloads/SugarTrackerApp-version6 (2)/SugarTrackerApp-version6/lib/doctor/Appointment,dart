import 'package:flutter/material.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:intl/intl.dart'; // ستحتاجين لإضافة intl في pubspec.yaml للتعامل مع التواريخ

class DoctorSchedulePage extends StatefulWidget {
  const DoctorSchedulePage({super.key});

  @override
  State<DoctorSchedulePage> createState() => _DoctorSchedulePageState();
}

class _DoctorSchedulePageState extends State<DoctorSchedulePage> {
  // التاريخ المختار حالياً (افتراضياً هو تاريخ اليوم)
  DateTime _selectedDate = DateTime.now();

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF8F9FB),
      body: Row(
        children: [
          // 1. القائمة الجانبية (Left Side) - التقويم الديناميكي
          _buildDynamicCalendar(),

          // 2. الجزء الرئيسي (Right Side) - جدول المواعيد
          Expanded(
            child: Padding(
              padding: const EdgeInsets.all(30.0),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  _buildHeader(),
                  const SizedBox(height: 30),
                  Expanded(child: _buildTimeSlotsList()),
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  // بناء التقويم الجانبي الذي يتغير حسب الشهر واليوم
 Widget _buildDynamicCalendar() {
  return Container(
    width: 300,
    decoration: const BoxDecoration(
      color: Colors.white,
      border: Border(right: BorderSide(color: Color(0xFFE5E7EB))),
    ),
    child: TableCalendar(
      firstDay: DateTime.utc(2024, 1, 1),
      lastDay: DateTime.utc(2030, 12, 31),
      focusedDay: _selectedDate,
      selectedDayPredicate: (day) => isSameDay(_selectedDate, day),
      onDaySelected: (selectedDay, focusedDay) {
        setState(() {
          _selectedDate = selectedDay;
        });
      },
      // --- التلوين والتنسيق (البرانسيب لي حبيتيه) ---
      headerStyle: const HeaderStyle(
        formatButtonVisible: false,
        titleCentered: true,
        titleTextStyle: TextStyle(fontWeight: FontWeight.bold, fontSize: 18),
      ),
      calendarStyle: CalendarStyle(
        // لون اليوم المختار (الأزرق مثل التصميم)
        selectedDecoration: const BoxDecoration(
          color: Color(0xFF2563EB),
          shape: BoxShape.circle,
        ),
        // لون يوم اليوم (دائرة فاتحة)
        todayDecoration: BoxDecoration(
          color: const Color(0xFF2563EB).withOpacity(0.2),
          shape: BoxShape.circle,
        ),
        todayTextStyle: const TextStyle(color: Color(0xFF2563EB), fontWeight: FontWeight.bold),
        
        // تنسيق أيام الأسبوع
        defaultTextStyle: const TextStyle(color: Color(0xFF1E293B)),
        weekendTextStyle: const TextStyle(color: Colors.redAccent),
      ),
      daysOfWeekStyle: const DaysOfWeekStyle(
        weekdayStyle: TextStyle(fontWeight: FontWeight.bold, color: Colors.grey),
        weekendStyle: TextStyle(fontWeight: FontWeight.bold, color: Colors.grey),
      ),
    ),
  );
}

  // بناء قائمة المواعيد المربوطة بـ Firebase
// --- ميثود عرض قائمة الساعات المربوطة بـ Firebase ---
Widget _buildTimeSlotsList() {
    // قائمة الساعات اليومية
    List<String> hours = ["09:00", "09:30", "10:00", "10:30", "11:00", "11:30", "14:00", "14:30"];
    
    // تنسيق التاريخ المختار لمطابقته مع Firebase
    String formattedDate = DateFormat('yyyy-MM-dd').format(_selectedDate);

    return StreamBuilder<QuerySnapshot>(
      // نجلب فقط مواعيد اليوم المختار
      stream: FirebaseFirestore.instance
          .collection('appointments')
          .where('date', isEqualTo: formattedDate)
          .snapshots(),
      builder: (context, snapshot) {
        if (!snapshot.hasData) return const Center(child: CircularProgressIndicator());

        // تحويل البيانات لسهولة عرضها حسب الساعة
        Map<String, dynamic> appointmentsMap = {};
        for (var doc in snapshot.data!.docs) {
          var data = doc.data() as Map<String, dynamic>;
          appointmentsMap[data['time']] = data;
        }

        return ListView.builder(
          itemCount: hours.length,
          itemBuilder: (context, index) {
            String hour = hours[index];
            var appointment = appointmentsMap[hour];

            return Padding(
              padding: const EdgeInsets.only(bottom: 20),
              child: Row(
                children: [
                  Text(hour, style: const TextStyle(color: Colors.grey, fontWeight: FontWeight.bold)),
                  const SizedBox(width: 30),
                  Expanded(
                    child: appointment != null
                        ? _buildPatientCard(appointment) // خانة محجوزة (زرقاء)
                        : _buildAvailableSlot(),        // خانة فارغة (منقطة)
                  ),
                ],
              ),
            );
          },
        );
      },
    );
  }

  // --- شكل كارت المريض (John Smith Style) ---
  Widget _buildPatientCard(Map<String, dynamic> data) {
    return Container(
      padding: const EdgeInsets.all(20),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(15),
        boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.05), blurRadius: 10)],
        border: const Border(left: BorderSide(color: Color(0xFF2563EB), width: 5)),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(data['patientName'], style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 16)),
              Text(data['type'], style: const TextStyle(color: Colors.grey)),
            ],
          ),
          ElevatedButton(
            onPressed: () {}, 
            style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF2563EB)),
            child: const Text("Join Call", style: TextStyle(color: Colors.white)),
          )
        ],
      ),
    );
  }

  // --- شكل الخانة الفارغة (Available Slot Style) ---
  Widget _buildAvailableSlot() {
    return Container(
      height: 70,
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(15),
        border: Border.all(color: Colors.grey.shade300, style: BorderStyle.solid),
      ),
      child: const Center(
        child: Text("Available Slot", style: TextStyle(color: Colors.grey, fontWeight: FontWeight.w500)),
      ),
    );
  }

  Widget _buildHeader() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: [
        Text(
          "Schedule - ${DateFormat('EEEE, d MMMM').format(_selectedDate)}",
          style: const TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
        ),
        const CircleAvatar(radius: 20, backgroundColor: Colors.blue),
      ],
    );
  }
}